{
  "doctype": "DocType",
  "name": "Driver License",
  "module": "Vehicle Rental Management",
  "autoname": "naming_series:",
  "fields": [
    {"fieldname": "naming_series", "fieldtype": "Select", "options": "DL-.#####"},
    {"fieldname": "driver", "fieldtype": "Link", "options": "Driver", "reqd": 1, "in_list_view": 1},
    {"fieldname": "license_number", "fieldtype": "Data", "reqd": 1, "unique": 1, "in_list_view": 1},
    {"fieldname": "license_class", "fieldtype": "Data", "in_list_view": 1},
    {"fieldname": "issue_date", "fieldtype": "Date"},
    {"fieldname": "expiry_date", "fieldtype": "Date", "reqd": 1, "in_list_view": 1},
    {"fieldname": "issuing_authority", "fieldtype": "Data"},
    {"fieldname": "issuing_country", "fieldtype": "Data"},
    {"fieldname": "license_scan", "fieldtype": "Attach", "label": "Scan Copy"},
    {"fieldname": "is_verified", "fieldtype": "Check", "label": "Verified", "default": "0"}
  ],
  "permissions": [
    {"role": "Fleet Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "Rental Agent", "read": 1, "write": 1, "create": 1}
  ]
}
