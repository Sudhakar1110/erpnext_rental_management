{
  "doctype": "DocType",
  "name": "Vehicle Insurance",
  "module": "Vehicle Rental Management",
  "autoname": "naming_series:",
  "fields": [
    {"fieldname": "naming_series", "fieldtype": "Select", "options": "VINS-.YYYY.-.#####"},
    {"fieldname": "vehicle", "fieldtype": "Link", "options": "Vehicle", "reqd": 1, "in_list_view": 1},
    {"fieldname": "policy_number", "fieldtype": "Data", "reqd": 1, "unique": 1, "in_list_view": 1},
    {"fieldname": "insurer", "fieldtype": "Data", "reqd": 1, "in_list_view": 1},
    {"fieldname": "insurance_type", "fieldtype": "Select",
      "options": "Third Party\nComprehensive\nThird Party Fire & Theft"},
    {"fieldname": "cb1", "fieldtype": "Column Break"},
    {"fieldname": "start_date", "fieldtype": "Date", "reqd": 1},
    {"fieldname": "expiry_date", "fieldtype": "Date", "reqd": 1, "in_list_view": 1},
    {"fieldname": "premium_amount", "fieldtype": "Currency"},
    {"fieldname": "coverage_amount", "fieldtype": "Currency", "label": "Coverage Amount"},
    {"fieldname": "excess_amount", "fieldtype": "Currency", "label": "Excess / Deductible"},
    {"fieldname": "policy_document", "fieldtype": "Attach", "label": "Policy Document"},
    {"fieldname": "notes", "fieldtype": "Small Text"},
    {"fieldname": "is_active", "fieldtype": "Check", "default": "1", "in_list_view": 1}
  ],
  "permissions": [
    {"role": "Fleet Manager", "read": 1, "write": 1, "create": 1, "delete": 1}
  ]
}
