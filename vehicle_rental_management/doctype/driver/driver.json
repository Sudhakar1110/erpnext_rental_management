{
  "doctype": "DocType",
  "name": "Driver",
  "module": "Vehicle Rental Management",
  "autoname": "naming_series:",
  "title_field": "full_name",
  "fields": [
    {"fieldname": "naming_series", "fieldtype": "Select", "options": "DRV-.#####", "default": "DRV-.#####"},
    {"fieldname": "full_name", "fieldtype": "Data", "label": "Full Name", "reqd": 1, "in_list_view": 1},
    {"fieldname": "date_of_birth", "fieldtype": "Date", "label": "Date of Birth"},
    {"fieldname": "nationality", "fieldtype": "Data", "label": "Nationality"},
    {"fieldname": "id_number", "fieldtype": "Data", "label": "National ID / Passport"},
    {"fieldname": "cb1", "fieldtype": "Column Break"},
    {"fieldname": "phone", "fieldtype": "Phone", "label": "Phone", "in_list_view": 1},
    {"fieldname": "email", "fieldtype": "Data", "options": "Email", "label": "Email"},
    {"fieldname": "address", "fieldtype": "Small Text", "label": "Address"},
    {"fieldname": "sec_license", "fieldtype": "Section Break", "label": "License Details"},
    {"fieldname": "license_number", "fieldtype": "Data", "label": "License Number"},
    {"fieldname": "license_class", "fieldtype": "Select", "options": "A\nB\nC\nD\nB+E", "label": "License Class"},
    {"fieldname": "license_expiry", "fieldtype": "Date", "label": "License Expiry", "in_list_view": 1},
    {"fieldname": "license_issuing_country", "fieldtype": "Data", "label": "Issuing Country"},
    {"fieldname": "license_scan", "fieldtype": "Attach", "label": "License Scan"},
    {"fieldname": "sec_status", "fieldtype": "Section Break"},
    {"fieldname": "status", "fieldtype": "Select",
      "options": "Active\nInactive\nSuspended",
      "default": "Active", "in_list_view": 1},
    {"fieldname": "photo", "fieldtype": "Attach Image", "label": "Photo"},
    {"fieldname": "notes", "fieldtype": "Small Text", "label": "Notes"}
  ],
  "permissions": [
    {"role": "Fleet Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "Rental Agent", "read": 1, "write": 1, "create": 1}
  ]
}
