{
  "doctype": "DocType",
  "name": "Vehicle Document",
  "module": "Vehicle Rental Management",
  "autoname": "naming_series:",
  "fields": [
    {"fieldname": "naming_series", "fieldtype": "Select", "options": "VDOC-.#####"},
    {"fieldname": "vehicle", "fieldtype": "Link", "options": "Vehicle", "reqd": 1, "in_list_view": 1},
    {"fieldname": "document_type", "fieldtype": "Select",
      "options": "Registration Certificate\nRoadworthiness Certificate\nPermit\nFranchise Document\nOther",
      "reqd": 1, "in_list_view": 1},
    {"fieldname": "document_number", "fieldtype": "Data", "in_list_view": 1},
    {"fieldname": "issue_date", "fieldtype": "Date"},
    {"fieldname": "expiry_date", "fieldtype": "Date", "in_list_view": 1},
    {"fieldname": "issuing_authority", "fieldtype": "Data"},
    {"fieldname": "document_file", "fieldtype": "Attach"},
    {"fieldname": "notes", "fieldtype": "Small Text"}
  ],
  "permissions": [
    {"role": "Fleet Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "Rental Agent", "read": 1}
  ]
}
