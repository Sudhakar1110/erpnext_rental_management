{
  "doctype": "DocType",
  "name": "Vehicle",
  "module": "Vehicle Rental Management",
  "engine": "InnoDB",
  "autoname": "naming_series:",
  "naming_rule": "By \"Naming Series\" field",
  "title_field": "license_plate",
  "track_changes": 1,
  "is_submittable": 0,
  "fields": [
    {"fieldname": "naming_series", "fieldtype": "Select", "label": "Series", "options": "VEH-.#####", "default": "VEH-.#####"},
    {"fieldname": "license_plate", "fieldtype": "Data", "label": "License Plate", "reqd": 1, "unique": 1, "in_list_view": 1},
    {"fieldname": "vin", "fieldtype": "Data", "label": "VIN", "unique": 1},
    {"fieldname": "make", "fieldtype": "Link", "options": "Vehicle Make", "label": "Make", "reqd": 1, "in_list_view": 1},
    {"fieldname": "model", "fieldtype": "Link", "options": "Vehicle Model", "label": "Model", "reqd": 1, "in_list_view": 1},
    {"fieldname": "year", "fieldtype": "Int", "label": "Year"},
    {"fieldname": "category", "fieldtype": "Link", "options": "Vehicle Category", "label": "Category", "reqd": 1, "in_standard_filter": 1},
    {"fieldname": "cb1", "fieldtype": "Column Break"},
    {"fieldname": "color", "fieldtype": "Data", "label": "Color"},
    {"fieldname": "transmission", "fieldtype": "Select", "options": "Manual\nAutomatic\nCVT", "label": "Transmission"},
    {"fieldname": "fuel_type", "fieldtype": "Select", "options": "Petrol\nDiesel\nElectric\nHybrid\nLPG\nCNG", "label": "Fuel Type"},
    {"fieldname": "seats", "fieldtype": "Int", "label": "Seats"},
    {"fieldname": "luggage_capacity", "fieldtype": "Int", "label": "Luggage Capacity (L)"},
    {"fieldname": "odometer", "fieldtype": "Float", "label": "Odometer (km)"},
    {"fieldname": "sec_status", "fieldtype": "Section Break", "label": "Status & Location"},
    {"fieldname": "status", "fieldtype": "Select",
      "options": "Available\nRented\nMaintenance\nOut of Service\nReserved",
      "default": "Available", "in_list_view": 1, "in_standard_filter": 1},
    {"fieldname": "current_location", "fieldtype": "Link", "options": "Vehicle Location", "label": "Current Location", "in_list_view": 1},
    {"fieldname": "cb2", "fieldtype": "Column Break"},
    {"fieldname": "pricing_plan", "fieldtype": "Link", "options": "Rental Pricing Plan", "label": "Pricing Plan"},
    {"fieldname": "daily_rate", "fieldtype": "Currency", "label": "Default Daily Rate"},
    {"fieldname": "weekly_rate", "fieldtype": "Currency", "label": "Weekly Rate"},
    {"fieldname": "monthly_rate", "fieldtype": "Currency", "label": "Monthly Rate"},
    {"fieldname": "deposit_amount", "fieldtype": "Currency", "label": "Security Deposit"},
    {"fieldname": "sec_docs", "fieldtype": "Section Break", "label": "Documents & Compliance"},
    {"fieldname": "registration_number", "fieldtype": "Data", "label": "Registration Number"},
    {"fieldname": "registration_expiry", "fieldtype": "Date", "label": "Registration Expiry"},
    {"fieldname": "insurance_policy", "fieldtype": "Data", "label": "Insurance Policy No."},
    {"fieldname": "insurance_expiry", "fieldtype": "Date", "label": "Insurance Expiry"},
    {"fieldname": "cb3", "fieldtype": "Column Break"},
    {"fieldname": "next_service_date", "fieldtype": "Date", "label": "Next Service Date"},
    {"fieldname": "next_service_km", "fieldtype": "Float", "label": "Next Service (km)"},
    {"fieldname": "roadworthiness_expiry", "fieldtype": "Date", "label": "Roadworthiness Expiry"},
    {"fieldname": "sec_features", "fieldtype": "Section Break", "label": "Features"},
    {"fieldname": "features", "fieldtype": "Small Text", "label": "Features (comma-separated)",
      "description": "e.g. AC, GPS, Bluetooth, Sunroof, Backup Camera"},
    {"fieldname": "sec_img", "fieldtype": "Section Break", "label": "Images"},
    {"fieldname": "image", "fieldtype": "Attach Image", "label": "Main Image"},
    {"fieldname": "additional_images", "fieldtype": "Small Text", "label": "Additional Image URLs"},
    {"fieldname": "sec_notes", "fieldtype": "Section Break", "label": "Internal Notes"},
    {"fieldname": "notes", "fieldtype": "Text Editor", "label": "Notes"}
  ],
  "permissions": [
    {"role": "Fleet Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "export": 1, "report": 1},
    {"role": "Rental Agent", "read": 1, "write": 1, "create": 1, "report": 1},
    {"role": "Mechanic", "read": 1, "write": 1},
    {"role": "Driver", "read": 1}
  ]
}
