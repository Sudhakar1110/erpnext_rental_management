{
  "doctype": "DocType",
  "name": "Rental Extra",
  "module": "Vehicle Rental Management",
  "autoname": "field:extra_name",
  "fields": [
    {"fieldname": "extra_name", "fieldtype": "Data", "label": "Extra Name", "reqd": 1, "unique": 1, "in_list_view": 1},
    {"fieldname": "extra_type", "fieldtype": "Select",
      "options": "Per Day\nPer Rental\nOne-Time",
      "label": "Charge Type", "reqd": 1, "in_list_view": 1},
    {"fieldname": "rate", "fieldtype": "Currency", "label": "Rate", "reqd": 1, "in_list_view": 1},
    {"fieldname": "description", "fieldtype": "Small Text", "label": "Description"},
    {"fieldname": "is_active", "fieldtype": "Check", "label": "Active", "default": "1"},
    {"fieldname": "image", "fieldtype": "Attach Image", "label": "Image"}
  ],
  "permissions": [
    {"role": "Fleet Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "Rental Agent", "read": 1}
  ]
}
