{
  "doctype": "DocType",
  "name": "Rental Agreement",
  "module": "Vehicle Rental Management",
  "autoname": "naming_series:",
  "is_submittable": 1,
  "track_changes": 1,
  "fields": [
    {"fieldname": "naming_series", "fieldtype": "Select", "options": "RA-.YYYY.-.#####", "default": "RA-.YYYY.-.#####"},
    {"fieldname": "booking", "fieldtype": "Link", "options": "Rental Booking", "label": "Booking", "reqd": 1, "in_list_view": 1},
    {"fieldname": "customer", "fieldtype": "Link", "options": "Customer", "label": "Customer", "reqd": 1, "in_list_view": 1, "fetch_from": "booking.customer"},
    {"fieldname": "vehicle", "fieldtype": "Link", "options": "Vehicle", "label": "Vehicle", "reqd": 1, "fetch_from": "booking.vehicle"},
    {"fieldname": "cb1", "fieldtype": "Column Break"},
    {"fieldname": "agreement_date", "fieldtype": "Date", "label": "Agreement Date", "reqd": 1, "default": "Today"},
    {"fieldname": "pickup_date", "fieldtype": "Datetime", "label": "Pickup Date"},
    {"fieldname": "return_date", "fieldtype": "Datetime", "label": "Return Date"},
    {"fieldname": "sec_financial", "fieldtype": "Section Break", "label": "Financial Terms"},
    {"fieldname": "grand_total", "fieldtype": "Currency", "label": "Grand Total", "fetch_from": "booking.grand_total"},
    {"fieldname": "deposit_amount", "fieldtype": "Currency", "label": "Security Deposit"},
    {"fieldname": "deposit_returned", "fieldtype": "Check", "label": "Deposit Returned"},
    {"fieldname": "cb2", "fieldtype": "Column Break"},
    {"fieldname": "payment_status", "fieldtype": "Select",
      "options": "Pending\nPartially Paid\nPaid\nRefunded",
      "default": "Pending", "label": "Payment Status"},
    {"fieldname": "sales_invoice", "fieldtype": "Link", "options": "Sales Invoice", "label": "Sales Invoice", "read_only": 1},
    {"fieldname": "sec_terms", "fieldtype": "Section Break", "label": "Terms & Conditions"},
    {"fieldname": "terms_and_conditions", "fieldtype": "Text Editor", "label": "Terms & Conditions"},
    {"fieldname": "customer_signature", "fieldtype": "Attach Image", "label": "Customer Signature"},
    {"fieldname": "agent_signature", "fieldtype": "Attach Image", "label": "Agent Signature"},
    {"fieldname": "sec_status", "fieldtype": "Section Break"},
    {"fieldname": "status", "fieldtype": "Select",
      "options": "Draft\nActive\nCompleted\nCancelled",
      "default": "Draft", "in_list_view": 1}
  ],
  "permissions": [
    {"role": "Fleet Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1, "delete": 1},
    {"role": "Rental Agent", "read": 1, "write": 1, "create": 1, "submit": 1}
  ]
}
