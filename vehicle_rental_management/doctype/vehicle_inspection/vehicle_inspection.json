{
  "doctype": "DocType",
  "name": "Vehicle Inspection",
  "module": "Vehicle Rental Management",
  "autoname": "naming_series:",
  "track_changes": 1,
  "is_submittable": 1,
  "fields": [
    {"fieldname": "naming_series", "fieldtype": "Select", "options": "VINSP-.YYYY.-.#####"},
    {"fieldname": "vehicle", "fieldtype": "Link", "options": "Vehicle", "reqd": 1, "in_list_view": 1},
    {"fieldname": "booking", "fieldtype": "Link", "options": "Rental Booking", "in_list_view": 1},
    {"fieldname": "inspection_type", "fieldtype": "Select",
      "options": "Pre-Checkout\nPost-Return\nRoutine",
      "reqd": 1, "in_list_view": 1},
    {"fieldname": "inspection_date", "fieldtype": "Datetime", "reqd": 1, "default": "Now"},
    {"fieldname": "inspector", "fieldtype": "Link", "options": "User", "default": "__user"},
    {"fieldname": "cb1", "fieldtype": "Column Break"},
    {"fieldname": "odometer_reading", "fieldtype": "Float", "label": "Odometer (km)"},
    {"fieldname": "fuel_level", "fieldtype": "Select",
      "options": "Empty\n1/4\n1/2\n3/4\nFull", "label": "Fuel Level"},
    {"fieldname": "overall_condition", "fieldtype": "Select",
      "options": "Excellent\nGood\nFair\nPoor", "label": "Overall Condition"},
    {"fieldname": "sec_checks", "fieldtype": "Section Break", "label": "Checklist"},
    {"fieldname": "exterior_clean", "fieldtype": "Check", "label": "Exterior Clean"},
    {"fieldname": "interior_clean", "fieldtype": "Check", "label": "Interior Clean"},
    {"fieldname": "tyres_ok", "fieldtype": "Check", "label": "Tyres OK"},
    {"fieldname": "spare_tyre_present", "fieldtype": "Check", "label": "Spare Tyre Present"},
    {"fieldname": "documents_present", "fieldtype": "Check", "label": "All Documents Present"},
    {"fieldname": "cb2", "fieldtype": "Column Break"},
    {"fieldname": "jack_present", "fieldtype": "Check", "label": "Jack & Tools Present"},
    {"fieldname": "fire_extinguisher", "fieldtype": "Check", "label": "Fire Extinguisher"},
    {"fieldname": "first_aid_kit", "fieldtype": "Check", "label": "First Aid Kit"},
    {"fieldname": "lights_ok", "fieldtype": "Check", "label": "All Lights Functional"},
    {"fieldname": "brakes_ok", "fieldtype": "Check", "label": "Brakes OK"},
    {"fieldname": "sec_damage", "fieldtype": "Section Break", "label": "Damage & Notes"},
    {"fieldname": "existing_damage", "fieldtype": "Text Editor", "label": "Existing Damage Notes"},
    {"fieldname": "photos", "fieldtype": "Attach", "label": "Inspection Photos"},
    {"fieldname": "customer_acknowledgement", "fieldtype": "Check", "label": "Customer Acknowledged"},
    {"fieldname": "customer_signature", "fieldtype": "Attach Image", "label": "Customer Signature"},
    {"fieldname": "inspector_notes", "fieldtype": "Small Text", "label": "Inspector Notes"}
  ],
  "permissions": [
    {"role": "Fleet Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1, "delete": 1, "amend": 1},
    {"role": "Rental Agent", "read": 1, "write": 1, "create": 1},
    {"role": "Mechanic", "read": 1, "write": 1, "create": 1}
  ]
}
