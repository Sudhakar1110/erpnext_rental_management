{
  "doctype": "DocType",
  "name": "Rental Booking",
  "module": "Vehicle Rental Management",
  "autoname": "naming_series:",
  "is_submittable": 1,
  "track_changes": 1,
  "title_field": "name",
  "fields": [
    {"fieldname": "naming_series", "fieldtype": "Select", "options": "RB-.YYYY.-.#####", "default": "RB-.YYYY.-.#####"},
    {"fieldname": "customer", "fieldtype": "Link", "options": "Customer", "reqd": 1, "in_list_view": 1},
    {"fieldname": "vehicle", "fieldtype": "Link", "options": "Vehicle", "reqd": 1, "in_list_view": 1},
    {"fieldname": "driver", "fieldtype": "Link", "options": "Driver", "label": "Assigned Driver"},
    {"fieldname": "cb1", "fieldtype": "Column Break"},
    {"fieldname": "pickup_date", "fieldtype": "Datetime", "label": "Pickup Date/Time", "reqd": 1, "in_list_view": 1},
    {"fieldname": "return_date", "fieldtype": "Datetime", "label": "Return Date/Time", "reqd": 1, "in_list_view": 1},
    {"fieldname": "pickup_location", "fieldtype": "Link", "options": "Vehicle Location", "reqd": 1},
    {"fieldname": "return_location", "fieldtype": "Link", "options": "Vehicle Location", "reqd": 1},
    {"fieldname": "sec_pricing", "fieldtype": "Section Break", "label": "Pricing"},
    {"fieldname": "pricing_plan", "fieldtype": "Link", "options": "Rental Pricing Plan", "label": "Pricing Plan"},
    {"fieldname": "daily_rate", "fieldtype": "Currency", "label": "Daily Rate"},
    {"fieldname": "rental_days", "fieldtype": "Int", "label": "Rental Days", "read_only": 1},
    {"fieldname": "base_amount", "fieldtype": "Currency", "label": "Base Amount", "read_only": 1},
    {"fieldname": "cb2", "fieldtype": "Column Break"},
    {"fieldname": "extras", "fieldtype": "Table", "options": "Rental Booking Extra", "label": "Extras / Add-ons"},
    {"fieldname": "extras_total", "fieldtype": "Currency", "label": "Extras Total", "read_only": 1},
    {"fieldname": "discount_amount", "fieldtype": "Currency", "label": "Discount"},
    {"fieldname": "tax_amount", "fieldtype": "Currency", "label": "Tax Amount", "read_only": 1},
    {"fieldname": "grand_total", "fieldtype": "Currency", "label": "Grand Total", "read_only": 1, "in_list_view": 1},
    {"fieldname": "deposit_amount", "fieldtype": "Currency", "label": "Security Deposit"},
    {"fieldname": "sec_status", "fieldtype": "Section Break", "label": "Status"},
    {"fieldname": "status", "fieldtype": "Select",
      "options": "Draft\nConfirmed\nChecked Out\nChecked In\nInvoiced\nClosed\nCancelled",
      "default": "Draft", "in_list_view": 1, "in_standard_filter": 1},
    {"fieldname": "agreement", "fieldtype": "Link", "options": "Rental Agreement", "label": "Agreement", "read_only": 1},
    {"fieldname": "source", "fieldtype": "Select", "options": "Walk-in\nPhone\nWebsite\nApp\nAgent\nOther", "label": "Booking Source"},
    {"fieldname": "sec_notes", "fieldtype": "Section Break", "label": "Notes"},
    {"fieldname": "special_requests", "fieldtype": "Small Text", "label": "Special Requests"},
    {"fieldname": "internal_notes", "fieldtype": "Small Text", "label": "Internal Notes"}
  ],
  "permissions": [
    {"role": "Fleet Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1, "delete": 1, "export": 1},
    {"role": "Rental Agent", "read": 1, "write": 1, "create": 1, "submit": 1},
    {"role": "Customer", "read": 1}
  ]
}
