{
  "doctype": "DocType",
  "name": "Fuel Log",
  "module": "Vehicle Rental Management",
  "autoname": "naming_series:",
  "fields": [
    {"fieldname": "naming_series", "fieldtype": "Select", "options": "FUEL-.YYYY.-.#####"},
    {"fieldname": "vehicle", "fieldtype": "Link", "options": "Vehicle", "reqd": 1, "in_list_view": 1},
    {"fieldname": "booking", "fieldtype": "Link", "options": "Rental Booking"},
    {"fieldname": "date", "fieldtype": "Date", "reqd": 1, "default": "Today", "in_list_view": 1},
    {"fieldname": "cb1", "fieldtype": "Column Break"},
    {"fieldname": "fuel_type", "fieldtype": "Select", "options": "Petrol\nDiesel\nElectric\nLPG"},
    {"fieldname": "litres", "fieldtype": "Float", "label": "Litres / kWh"},
    {"fieldname": "cost_per_litre", "fieldtype": "Currency"},
    {"fieldname": "total_cost", "fieldtype": "Currency", "read_only": 1},
    {"fieldname": "odometer", "fieldtype": "Float", "label": "Odometer at Fill (km)"},
    {"fieldname": "station", "fieldtype": "Data", "label": "Fuel Station"},
    {"fieldname": "receipt", "fieldtype": "Attach", "label": "Receipt"},
    {"fieldname": "notes", "fieldtype": "Small Text"}
  ],
  "permissions": [
    {"role": "Fleet Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "Rental Agent", "read": 1, "write": 1, "create": 1},
    {"role": "Driver", "read": 1, "write": 1, "create": 1}
  ]
}
