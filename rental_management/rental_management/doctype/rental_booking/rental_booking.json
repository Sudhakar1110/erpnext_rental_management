{
  "doctype": "DocType",
  "name": "Rental Booking",
  "module": "Rental Management",
  "custom": 0,
  "istable": 0,
  "editable_grid": 1,
  "engine": "InnoDB",
  "track_changes": 1,
  "is_submittable": 1,
  "naming_rule": "Expression (old style)",
  "autoname": "RB-.YYYY.-.#####",
  "title_field": "customer_name",
  "search_fields": "customer,vehicle,status",
  "fields": [
    {"fieldname": "customer", "fieldtype": "Link", "label": "Customer", "options": "Customer", "reqd": 1, "in_list_view": 1, "in_standard_filter": 1},
    {"fieldname": "customer_name", "fieldtype": "Data", "label": "Customer Name", "fetch_from": "customer.customer_name", "read_only": 1, "in_list_view": 1},
    {"fieldname": "vehicle", "fieldtype": "Link", "label": "Vehicle", "options": "Rental Vehicle", "reqd": 1, "in_list_view": 1, "in_standard_filter": 1},
    {"fieldname": "col_break_1", "fieldtype": "Column Break"},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Draft\nConfirmed\nActive\nCompleted\nCancelled", "default": "Draft", "reqd": 1, "in_list_view": 1, "in_standard_filter": 1, "read_only": 1},
    {"fieldname": "booking_date", "fieldtype": "Date", "label": "Booking Date", "default": "Today", "reqd": 1},
    {"fieldname": "section_dates", "fieldtype": "Section Break", "label": "Rental Period"},
    {"fieldname": "start_date", "fieldtype": "Date", "label": "Start Date", "reqd": 1, "in_list_view": 1},
    {"fieldname": "end_date", "fieldtype": "Date", "label": "End Date", "reqd": 1, "in_list_view": 1},
    {"fieldname": "total_days", "fieldtype": "Int", "label": "Total Days", "read_only": 1},
    {"fieldname": "col_break_2", "fieldtype": "Column Break"},
    {"fieldname": "pickup_location", "fieldtype": "Data", "label": "Pickup Location"},
    {"fieldname": "return_location", "fieldtype": "Data", "label": "Return Location"},
    {"fieldname": "section_financials", "fieldtype": "Section Break", "label": "Financials"},
    {"fieldname": "daily_rate", "fieldtype": "Currency", "label": "Daily Rate", "read_only": 1, "fetch_from": "vehicle.daily_rate"},
    {"fieldname": "rental_amount", "fieldtype": "Currency", "label": "Rental Amount", "read_only": 1},
    {"fieldname": "damage_deposit", "fieldtype": "Currency", "label": "Damage Deposit", "read_only": 1, "fetch_from": "vehicle.damage_deposit"},
    {"fieldname": "col_break_3", "fieldtype": "Column Break"},
    {"fieldname": "discount_percent", "fieldtype": "Percent", "label": "Discount (%)", "default": "0"},
    {"fieldname": "discount_amount", "fieldtype": "Currency", "label": "Discount Amount", "read_only": 1},
    {"fieldname": "grand_total", "fieldtype": "Currency", "label": "Grand Total", "read_only": 1, "bold": 1},
    {"fieldname": "currency", "fieldtype": "Link", "label": "Currency", "options": "Currency", "default": "INR"},
    {"fieldname": "section_driver", "fieldtype": "Section Break", "label": "Driver / License"},
    {"fieldname": "driver_name", "fieldtype": "Data", "label": "Driver Name"},
    {"fieldname": "driving_license_no", "fieldtype": "Data", "label": "Driving License No"},
    {"fieldname": "col_break_4", "fieldtype": "Column Break"},
    {"fieldname": "license_expiry_date", "fieldtype": "Date", "label": "License Expiry Date"},
    {"fieldname": "id_proof_type", "fieldtype": "Select", "label": "ID Proof Type", "options": "\nAadhaar\nPassport\nVoter ID\nPAN Card"},
    {"fieldname": "id_proof_number", "fieldtype": "Data", "label": "ID Proof Number"},
    {"fieldname": "section_notes", "fieldtype": "Section Break", "label": "Notes & Remarks"},
    {"fieldname": "remarks", "fieldtype": "Text Editor", "label": "Remarks"}
  ],
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "amend": 1, "report": 1, "export": 1, "import": 1, "share": 1, "print": 1, "email": 1},
    {"role": "Rental Manager", "read": 1, "write": 1, "create": 1, "delete": 0, "submit": 1, "cancel": 1, "amend": 1, "report": 1, "export": 1, "print": 1, "email": 1},
    {"role": "Rental User", "read": 1, "write": 1, "create": 1, "delete": 0, "submit": 0, "cancel": 0, "amend": 0, "report": 1, "print": 1, "email": 1}
  ]
}
