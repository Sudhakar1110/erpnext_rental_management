{
  "doctype": "DocType",
  "name": "Rental Payment",
  "module": "Rental Management",
  "custom": 0,
  "istable": 0,
  "editable_grid": 1,
  "engine": "InnoDB",
  "track_changes": 1,
  "is_submittable": 1,
  "naming_rule": "Expression (old style)",
  "autoname": "RP-.YYYY.-.#####",
  "title_field": "booking",
  "search_fields": "booking,customer,status",
  "fields": [
    {"fieldname": "booking", "fieldtype": "Link", "label": "Rental Booking", "options": "Rental Booking", "reqd": 1, "in_list_view": 1, "in_standard_filter": 1},
    {"fieldname": "customer", "fieldtype": "Link", "label": "Customer", "options": "Customer", "reqd": 1, "in_list_view": 1},
    {"fieldname": "payment_date", "fieldtype": "Date", "label": "Payment Date", "default": "Today", "reqd": 1, "in_list_view": 1},
    {"fieldname": "col_break_1", "fieldtype": "Column Break"},
    {"fieldname": "amount", "fieldtype": "Currency", "label": "Amount", "reqd": 1, "in_list_view": 1},
    {"fieldname": "payment_mode", "fieldtype": "Select", "label": "Payment Mode", "options": "Cash\nCheque\nBank Transfer\nUPI\nCredit Card\nDebit Card", "reqd": 1, "in_list_view": 1},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Pending\nReceived\nRefunded\nFailed", "default": "Pending", "reqd": 1, "in_list_view": 1, "read_only": 1},
    {"fieldname": "section_ref", "fieldtype": "Section Break", "label": "Reference"},
    {"fieldname": "reference_number", "fieldtype": "Data", "label": "Reference / Transaction Number"},
    {"fieldname": "payment_type", "fieldtype": "Select", "label": "Payment Type", "options": "Rental Amount\nDamage Deposit\nOverdue Charges\nRefund", "reqd": 1},
    {"fieldname": "col_break_2", "fieldtype": "Column Break"},
    {"fieldname": "remarks", "fieldtype": "Small Text", "label": "Remarks"}
  ],
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "amend": 1, "report": 1, "export": 1, "print": 1, "email": 1},
    {"role": "Rental Manager", "read": 1, "write": 1, "create": 1, "delete": 0, "submit": 1, "cancel": 1, "amend": 0, "report": 1, "export": 1, "print": 1, "email": 1},
    {"role": "Accounts User", "read": 1, "write": 1, "create": 1, "delete": 0, "submit": 1, "cancel": 0, "amend": 0, "report": 1, "print": 1, "email": 1}
  ]
}
