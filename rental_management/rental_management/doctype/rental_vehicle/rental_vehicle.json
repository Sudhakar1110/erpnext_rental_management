{
  "doctype": "DocType",
  "name": "Rental Vehicle",
  "module": "Rental Management",
  "custom": 0,
  "istable": 0,
  "editable_grid": 1,
  "engine": "InnoDB",
  "track_changes": 1,
  "is_submittable": 0,
  "naming_rule": "By fieldname",
  "autoname": "field:license_plate",
  "title_field": "vehicle_name",
  "search_fields": "license_plate,vehicle_name,category",
  "fields": [
    {"fieldname": "vehicle_name", "fieldtype": "Data", "label": "Vehicle Name", "reqd": 1, "in_list_view": 1, "in_standard_filter": 1},
    {"fieldname": "license_plate", "fieldtype": "Data", "label": "License Plate", "reqd": 1, "unique": 1, "in_list_view": 1},
    {"fieldname": "category", "fieldtype": "Select", "label": "Category", "options": "Economy\nSedan\nSUV\nLuxury\nVan\nTruck", "reqd": 1, "in_list_view": 1, "in_standard_filter": 1},
    {"fieldname": "col_break_1", "fieldtype": "Column Break"},
    {"fieldname": "make", "fieldtype": "Data", "label": "Make", "reqd": 1},
    {"fieldname": "model", "fieldtype": "Data", "label": "Model", "reqd": 1},
    {"fieldname": "year", "fieldtype": "Int", "label": "Year", "reqd": 1},
    {"fieldname": "color", "fieldtype": "Data", "label": "Color"},
    {"fieldname": "section_rates", "fieldtype": "Section Break", "label": "Rental Rates"},
    {"fieldname": "daily_rate", "fieldtype": "Currency", "label": "Daily Rate", "reqd": 1, "in_list_view": 1},
    {"fieldname": "weekly_rate", "fieldtype": "Currency", "label": "Weekly Rate"},
    {"fieldname": "monthly_rate", "fieldtype": "Currency", "label": "Monthly Rate"},
    {"fieldname": "col_break_2", "fieldtype": "Column Break"},
    {"fieldname": "damage_deposit", "fieldtype": "Currency", "label": "Damage Deposit", "default": "0"},
    {"fieldname": "currency", "fieldtype": "Link", "label": "Currency", "options": "Currency", "default": "INR"},
    {"fieldname": "section_status", "fieldtype": "Section Break", "label": "Status & Availability"},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Available\nRented\nMaintenance\nRetired", "default": "Available", "reqd": 1, "in_list_view": 1, "in_standard_filter": 1},
    {"fieldname": "odometer_km", "fieldtype": "Float", "label": "Odometer (km)"},
    {"fieldname": "col_break_3", "fieldtype": "Column Break"},
    {"fieldname": "fuel_type", "fieldtype": "Select", "label": "Fuel Type", "options": "Petrol\nDiesel\nElectric\nHybrid\nCNG"},
    {"fieldname": "transmission", "fieldtype": "Select", "label": "Transmission", "options": "Manual\nAutomatic"},
    {"fieldname": "seating_capacity", "fieldtype": "Int", "label": "Seating Capacity"},
    {"fieldname": "section_notes", "fieldtype": "Section Break", "label": "Notes"},
    {"fieldname": "notes", "fieldtype": "Text Editor", "label": "Notes"}
  ],
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1, "export": 1, "import": 1, "share": 1, "print": 1, "email": 1},
    {"role": "Rental Manager", "read": 1, "write": 1, "create": 1, "delete": 0, "report": 1, "export": 1, "print": 1, "email": 1},
    {"role": "Rental User", "read": 1, "write": 0, "create": 0, "delete": 0, "report": 1, "print": 1}
  ]
}
